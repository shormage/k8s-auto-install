#!/bin/bash

# ============================================================
# R_SH Kubernetes Installer v2.0
# Configuration File
# ============================================================

APP_NAME="R_SH Kubernetes Installer"
APP_VERSION="2.0"

# Supported Kubernetes versions
K8S_VERSION_1="v1.34"
K8S_VERSION_2="v1.35"

# Runtime versions
CONTAINERD_VERSION="2.1.7"
RUNC_VERSION="1.4.2"
CNI_VERSION="1.8.0"

# Calico version
CALICO_VERSION="v3.30.6"

# Kubernetes pod network CIDR
# For Calico this value is OK
POD_CIDR="192.168.0.0/16"

# Directories
PACKAGES_DIR="packages"
LOGS_DIR="logs"

# Offline package filenames
CONTAINERD_PACKAGE="containerd-${CONTAINERD_VERSION}-linux-amd64.tar.gz"
RUNC_PACKAGE="runc.amd64"
CNI_PACKAGE="cni-plugins-linux-amd64-v${CNI_VERSION}.tgz"
CALICO_PACKAGE="calico-${CALICO_VERSION}.yaml"

# Kubernetes package filename pattern:
# kubernetes-v1.34-debs.tar.gz
# kubernetes-v1.35-debs.tar.gz

# Kubernetes image archive filename pattern:
# images-v1.34.tar
# images-v1.35.tar